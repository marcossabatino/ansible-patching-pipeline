<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Patch Management Report — {{ ansible_hostname }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --surface-2: #1c2430;
    --border: #30363d;
    --text: #c9d1d9;
    --text-dim: #8b949e;
    --accent: #58a6ff;
    --green: #3fb950;
    --red: #f85149;
    --yellow: #d29922;
    --mono: 'JetBrains Mono', ui-monospace, monospace;
    --sans: 'Inter', system-ui, sans-serif;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    line-height: 1.55;
    padding: 40px 20px;
  }
  .container { max-width: 960px; margin: 0 auto; }
  .badge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(63, 185, 80, 0.12);
    color: var(--green);
    border: 1px solid rgba(63, 185, 80, 0.3);
    margin-bottom: 16px;
  }
  h1 {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 8px;
    color: #f0f6fc;
  }
  .subtitle { color: var(--text-dim); margin-bottom: 32px; font-family: var(--mono); font-size: 13px; }
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
    margin-bottom: 20px;
  }
  .card h2 {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.3px;
    color: var(--text-dim);
    margin-bottom: 16px;
  }
  .meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
  }
  .meta-item { display: flex; flex-direction: column; gap: 4px; }
  .meta-label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }
  .meta-value { font-family: var(--mono); font-size: 14px; color: var(--text); }

  /* Pipeline stages */
  .pipeline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 8px;
  }
  .stage {
    flex: 1;
    min-width: 120px;
    text-align: center;
    padding: 16px 10px;
    background: var(--surface-2);
    border: 1px solid rgba(63, 185, 80, 0.4);
    border-radius: 8px;
    position: relative;
  }
  .stage .stage-name {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--green);
    text-transform: uppercase;
  }
  .stage .stage-status {
    margin-top: 6px;
    font-size: 18px;
    color: var(--green);
  }
  .arrow {
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 18px;
    flex: 0 0 auto;
  }

  /* Metric cards */
  .metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
  }
  .metric {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 18px;
  }
  .metric .label {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    color: var(--text-dim);
    letter-spacing: 0.8px;
    margin-bottom: 8px;
  }
  .metric .value {
    font-family: var(--mono);
    font-size: 26px;
    font-weight: 700;
  }
  .green { color: var(--green); }
  .red   { color: var(--red); }
  .yellow{ color: var(--yellow); }

  /* Progress bars */
  .bar-wrap { margin-bottom: 14px; }
  .bar-label {
    display: flex;
    justify-content: space-between;
    font-family: var(--mono);
    font-size: 12px;
    margin-bottom: 6px;
    color: var(--text-dim);
  }
  .bar {
    height: 8px;
    background: var(--surface-2);
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .bar-fill { height: 100%; border-radius: 4px; }

  /* Table */
  table { width: 100%; border-collapse: collapse; font-family: var(--mono); font-size: 13px; }
  th, td {
    text-align: left;
    padding: 10px 12px;
    border-bottom: 1px solid var(--border);
  }
  th { color: var(--text-dim); text-transform: uppercase; font-size: 11px; letter-spacing: 0.8px; }
  .chip {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    background: rgba(63, 185, 80, 0.15);
    color: var(--green);
    border: 1px solid rgba(63, 185, 80, 0.3);
  }

  ul.pkg-list { list-style: none; font-family: var(--mono); font-size: 13px; }
  ul.pkg-list li {
    padding: 6px 10px;
    border-bottom: 1px solid var(--border);
  }
  ul.pkg-list li:last-child { border-bottom: none; }

  footer {
    margin-top: 32px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 12px;
    text-align: center;
  }
</style>
</head>
<body>
<div class="container">

  <span class="badge">Patch Management Pipeline</span>
  <h1>Patch Report — {{ ansible_hostname }}</h1>
  <div class="subtitle">Generated {{ ansible_date_time.iso8601 }}</div>

  <div class="card">
    <h2>Host Information</h2>
    <div class="meta-grid">
      <div class="meta-item"><span class="meta-label">Host</span><span class="meta-value">{{ ansible_hostname }}</span></div>
      <div class="meta-item"><span class="meta-label">IP Address</span><span class="meta-value">{{ ansible_default_ipv4.address | default('N/A') }}</span></div>
      <div class="meta-item"><span class="meta-label">OS</span><span class="meta-value">{{ ansible_distribution }} {{ ansible_distribution_version }}</span></div>
      <div class="meta-item"><span class="meta-label">Kernel</span><span class="meta-value">{{ ansible_kernel }}</span></div>
      <div class="meta-item"><span class="meta-label">Patch Type</span><span class="meta-value">{{ patch_upgrade_type }}</span></div>
      <div class="meta-item"><span class="meta-label">Date</span><span class="meta-value">{{ ansible_date_time.date }}</span></div>
    </div>
  </div>

  <div class="card">
    <h2>Pipeline Status</h2>
    <div class="pipeline">
      <div class="stage"><div class="stage-name">Pre-check</div><div class="stage-status">✓</div></div>
      <span class="arrow">→</span>
      <div class="stage"><div class="stage-name">Snapshot</div><div class="stage-status">✓</div></div>
      <span class="arrow">→</span>
      <div class="stage"><div class="stage-name">Patch</div><div class="stage-status">✓</div></div>
      <span class="arrow">→</span>
      <div class="stage"><div class="stage-name">Reboot</div><div class="stage-status">✓</div></div>
      <span class="arrow">→</span>
      <div class="stage"><div class="stage-name">Post-check</div><div class="stage-status">✓</div></div>
    </div>
  </div>

  <div class="card">
    <h2>Key Metrics</h2>
    <div class="metrics">
      <div class="metric">
        <div class="label">Packages Upgraded</div>
        <div class="value {% if post_check_results.packages_upgraded | int > 0 %}green{% else %}yellow{% endif %}">
          {{ post_check_results.packages_upgraded }}
        </div>
      </div>
      <div class="metric">
        <div class="label">Remaining Upgrades</div>
        <div class="value {% if post_check_results.remaining_upgrades | int == 0 %}green{% else %}yellow{% endif %}">
          {{ post_check_results.remaining_upgrades }}
        </div>
      </div>
      <div class="metric">
        <div class="label">Reboot Performed</div>
        <div class="value {% if post_check_results.reboot_performed %}yellow{% else %}green{% endif %}">
          {{ 'YES' if post_check_results.reboot_performed else 'NO' }}
        </div>
      </div>
      <div class="metric">
        <div class="label">Critical Services</div>
        <div class="value green">ALL OK</div>
      </div>
    </div>
  </div>

  <div class="card">
    <h2>Pre-check Details</h2>
    {% set disk_pct = pre_check_results.disk_free_pct | int %}
    {% set mem_mb = pre_check_results.mem_free_mb | int %}
    <div class="bar-wrap">
      <div class="bar-label">
        <span>Disk Free</span>
        <span>{{ disk_pct }}% (min: {{ min_disk_free_percent }}%)</span>
      </div>
      <div class="bar">
        <div class="bar-fill" style="width: {{ disk_pct }}%; background: {% if disk_pct >= min_disk_free_percent %}var(--green){% else %}var(--red){% endif %};"></div>
      </div>
    </div>
    <div class="bar-wrap">
      <div class="bar-label">
        <span>Memory Free</span>
        <span>{{ mem_mb }} MB (min: {{ min_memory_free_mb }} MB)</span>
      </div>
      <div class="bar">
        {% set mem_pct = ((mem_mb / (min_memory_free_mb * 4)) * 100) | round | int %}
        {% if mem_pct > 100 %}{% set mem_pct = 100 %}{% endif %}
        <div class="bar-fill" style="width: {{ mem_pct }}%; background: {% if mem_mb >= min_memory_free_mb %}var(--green){% else %}var(--red){% endif %};"></div>
      </div>
    </div>
  </div>

  <div class="card">
    <h2>Critical Services</h2>
    <table>
      <thead>
        <tr><th>Service</th><th>Status</th></tr>
      </thead>
      <tbody>
        {% for svc in critical_services %}
        <tr>
          <td>{{ svc }}</td>
          <td><span class="chip">RUNNING</span></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Pinned Packages</h2>
    {% if pinned_packages | length > 0 %}
    <ul class="pkg-list">
      {% for pkg in pinned_packages %}
      <li>{{ pkg }}</li>
      {% endfor %}
    </ul>
    {% else %}
    <p style="color: var(--text-dim); font-family: var(--mono); font-size: 13px;">No packages pinned.</p>
    {% endif %}
  </div>

  <footer>
    ansible-patching-pipeline · fo:sabatino · fo:platform-engineering | generated at {{ ansible_date_time.iso8601 }}
  </footer>

</div>
</body>
</html>
